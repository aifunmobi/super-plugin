{
  "description": "Super plugin enforcement hooks: plan guard (no code without plan) and research tracker (artifact persistence + quality validation)",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/super-plan-guard.js\"",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/super-research-tracker.js\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}